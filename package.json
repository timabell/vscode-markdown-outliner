{
  "name": "markdown-outliner",
  "displayName": "Markdown Outliner",
  "description": "Adds collapsible sections to markdown preview for headings and lists",
  "version": "1.0.0",
  "publisher": "timabell",
  "author": "Tim Abell <tim@0x5.uk>",
  "engines": {
    "vscode": "^1.0.0"
  },
  "categories": [
    "Formatters",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "preview",
    "collapse",
    "fold",
    "outline"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "markdown.previewScripts": [
      "./media/outliner.js"
    ],
    "markdown.previewStyles": [
      "./media/outliner.css"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "jest",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/vsce": "^3.2.1",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/timabell/vscode-markdown-outliner.git"
  },
  "bugs": {
    "url": "https://github.com/timabell/vscode-markdown-outliner/issues"
  },
  "homepage": "https://github.com/timabell/vscode-markdown-outliner#readme",
  "license": "AGPL-3.0"
}
